---
import { getImage } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import LandingTemplate from '@templates/LandingTemplate.astro';
import { FAQ } from '@utils/constants';
import dashboardScreenshot from '../assets/screens/dashboard-2.webp';

const dashboardImage = await getImage({ src: dashboardScreenshot, width: 900 });

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'TerraCore',
    url: 'https://terracoreapp.co',
    logo: 'https://terracoreapp.co/logo.ico',
    description:
      'TerraCore ayuda a productores y administradores de finca a reducir pérdidas, controlar costos y tomar decisiones con datos reales. Funciona sin internet. Diseñada para el campo colombiano.',
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'Antioquia',
      addressCountry: 'CO',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+57-310-828-3088',
      contactType: 'customer support',
      email: 'contact@luminaw.co',
      availableLanguage: 'Spanish',
    },
    sameAs: ['https://luminaw.co'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'TerraCore',
    url: 'https://terracoreapp.co',
    description:
      'TerraCore ayuda a productores y administradores de finca a reducir pérdidas, controlar costos y tomar decisiones con datos reales. Funciona sin internet. Diseñada para el campo colombiano.',
    inLanguage: 'es-CO',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'TerraCore',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web, Android, iOS',
    url: 'https://terracoreapp.co',
    description:
      'Plataforma de gestión agroindustrial para reducir pérdidas, controlar costos y decidir con datos reales. Centraliza animales, salud, producción, insumos y finanzas de la finca en un solo lugar. Funciona sin internet y está diseñada para el campo colombiano.',
    inLanguage: 'es-CO',
    image: 'https://terracoreapp.co/terracore.jpg',
    screenshot: `https://terracoreapp.co${dashboardImage.src}`,
    cancellationNoticeRequired: 'P30D',
    provider: {
      '@type': 'Organization',
      name: 'TerraCore',
      url: 'https://terracoreapp.co',
    },
    offers: [
      {
        '@type': 'AggregateOffer',
        lowPrice: '2500000',
        highPrice: '10000000',
        priceCurrency: 'COP',
        offerCount: 3,
        description:
          'Tres planes mensuales desde COP $2.500.000/mes según el tamaño de la operación.',
        url: 'https://terracoreapp.co/#precios',
      },
      {
        '@type': 'Offer',
        name: 'Plan Semilla',
        priceCurrency: 'COP',
        price: '2500000',
        category: 'subscription',
        implementationTime: 'PT24H',
        url: 'https://terracoreapp.co/#precios',
        priceSpecification: {
          '@type': 'UnitPriceSpecification',
          priceCurrency: 'COP',
          price: '2500000',
          billingDuration: 'P1M',
        },
      },
      {
        '@type': 'Offer',
        name: 'Plan Profesional',
        priceCurrency: 'COP',
        price: '5000000',
        category: 'subscription',
        implementationTime: 'P5D',
        url: 'https://terracoreapp.co/#precios',
        priceSpecification: {
          '@type': 'UnitPriceSpecification',
          priceCurrency: 'COP',
          price: '5000000',
          billingDuration: 'P1M',
        },
      },
      {
        '@type': 'Offer',
        name: 'Plan Enterprise',
        priceCurrency: 'COP',
        price: '10000000',
        category: 'subscription',
        url: 'https://terracoreapp.co/#precios',
        priceSpecification: {
          '@type': 'UnitPriceSpecification',
          priceCurrency: 'COP',
          price: '10000000',
          billingDuration: 'P1M',
        },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    inLanguage: 'es-CO',
    mainEntity: FAQ.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    })),
  },
]);
---

<BaseLayout
  title="TerraCore: software de gestión agroindustrial en Colombia"
  description="Centraliza la gestión de tu finca, funciona sin internet y convierte las pérdidas evitadas en retorno real. Diseñada para fincas medianas en Colombia."
  preloadImage={dashboardImage.src}
>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />
  <LandingTemplate />
</BaseLayout>
