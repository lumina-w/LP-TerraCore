---
import { Icon } from 'astro-icon/components';
import { waLink } from '@utils/constants';
---

<a
  href={waLink('Hola, estoy interesado en TerraCore')}
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-float"
  aria-label="Escríbenos por WhatsApp (abre en una pestaña nueva)"
>
  <Icon name="simple-icons:whatsapp" width={28} height={28} aria-hidden="true" />
</a>

<style>
  .whatsapp-float {
    position: fixed;
    right: max(16px, env(safe-area-inset-right));
    bottom: max(16px, env(safe-area-inset-bottom));
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25d366;
    color: #fff;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
    transition:
      transform var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .whatsapp-float:hover {
    transform: scale(1.08);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.32);
  }
  .whatsapp-float:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 3px;
  }

  @media (max-width: 640px) {
    .whatsapp-float {
      width: 48px;
      height: 48px;
    }
    .whatsapp-float :global(svg) {
      width: 24px;
      height: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .whatsapp-float {
      transition: none;
    }
  }
</style>
