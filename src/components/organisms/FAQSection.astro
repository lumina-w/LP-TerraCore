---
import Eyebrow from '@atoms/Eyebrow.astro';
import { Icon } from 'astro-icon/components';
import { FAQ } from '@utils/constants';

// Shared source of truth with the FAQPage JSON-LD schema in index.astro.
const qs = FAQ;
---

<section class="section-pad reveal" id="preguntas">
  <div class="container">
    <div class="faq-wrap">
      <div>
        <Eyebrow num="06">Preguntas</Eyebrow>
        <h2 class="display lg" style="margin-top:16px; margin-bottom:16px">
          Las dudas<br />que siempre nos hacen.
        </h2>
        <p class="lead">
          ¿No ves la tuya? Escríbenos a{' '}
          <a href="mailto:contact@luminaw.co" class="faq-link">contact@luminaw.co</a>{' '}
          y te respondemos en menos de un día hábil.
        </p>
      </div>

      <div class="faq-list">
        {
          qs.map((it, i) => (
            <div class="faq-item" data-faq>
              <button
                class="faq-q"
                aria-expanded="false"
                aria-controls={`faq-a-${i}`}
                id={`faq-q-${i}`}
              >
                <span>{it.q}</span>
                <span class="faq-plus" aria-hidden="true">
                  <Icon name="lucide:plus" width={14} height={14} aria-hidden="true" />
                </span>
              </button>
              <div
                class="faq-a"
                id={`faq-a-${i}`}
                role="region"
                aria-labelledby={`faq-q-${i}`}
                hidden
              >
                <div class="faq-a-inner">{it.a}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll<HTMLElement>('[data-faq]');

  function closeItem(el: HTMLElement) {
    el.classList.remove('faq-item--open');
    const b = el.querySelector<HTMLButtonElement>('.faq-q')!;
    const a = el.querySelector<HTMLElement>('.faq-a')!;
    const wasOpen = b.getAttribute('aria-expanded') === 'true';
    b.setAttribute('aria-expanded', 'false');
    a.style.height = '0';
    if (wasOpen) {
      a.addEventListener(
        'transitionend',
        () => {
          if (b.getAttribute('aria-expanded') === 'false') a.hidden = true;
        },
        { once: true },
      );
    } else {
      a.hidden = true;
    }
  }

  items.forEach((item) => {
    const btn = item.querySelector<HTMLButtonElement>('.faq-q')!;
    const answer = item.querySelector<HTMLElement>('.faq-a')!;
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      items.forEach(closeItem);
      if (!isOpen) {
        answer.hidden = false;
        item.classList.add('faq-item--open');
        btn.setAttribute('aria-expanded', 'true');
        requestAnimationFrame(() => {
          answer.style.height = answer.scrollHeight + 'px';
        });
      }
    });
  });
</script>

<style>
  .faq-wrap {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 64px;
  }
  @media (max-width: 880px) {
    .faq-wrap {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .faq-link {
    color: var(--color-accent);
    font-weight: 600;
  }
  .faq-link:hover {
    color: var(--color-accent-hover);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0;
    font-size: 17px;
    font-weight: 600;
    color: var(--color-text);
    font-family: var(--font-display);
    letter-spacing: -0.01em;
    text-align: left;
    gap: 16px;
    cursor: pointer;
    transition: color var(--dur-base) var(--ease-standard);
  }
  .faq-q:hover {
    color: var(--color-primary);
  }

  .faq-plus {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    transition: all var(--dur-base) var(--ease-standard);
  }
  .faq-item--open .faq-plus {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
    transform: rotate(45deg);
  }

  .faq-a {
    overflow: hidden;
    height: 0;
    transition: height 240ms ease-out;
  }
  .faq-a-inner {
    padding-bottom: 24px;
    font-size: 15px;
    line-height: 24px;
    color: var(--color-text-secondary);
    max-width: 64ch;
  }
</style>
