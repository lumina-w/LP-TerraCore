# Google Analytics 4 — must use PUBLIC_ prefix to be available client-side
PUBLIC_GA_ID=G-XXXXXXXXXX

# Primary CTA href (optional; falls back to /#demo if absent)
MAIN_CTA_URL=/#demo

# Canonical site URL, read at build time in astro.config.mjs (site + sitemap)
# Optional; falls back to https://terracoreapp.co if absent
PUBLIC_SITE_URL=https://terracoreapp.co

# Contact WhatsApp number (digits only, country code first, no +).
# Read at build time in src/utils/constants.ts; falls back to 573108283088 if absent
CONTACT_WHATSAPP=573108283088
